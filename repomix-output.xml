  getRecentAlerts(username: string): Observable<Alert[]> {
    return this.http.get<Alert[]>(`${this.API_URL}/user/${username}`);
  }

  acknowledge(id: string): Observable<void> {
    return this.http.patch<void>(`${this.API_URL}/${id}/ack`, {});
