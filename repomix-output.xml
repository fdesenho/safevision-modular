    @Container
    @ServiceConnection
    static RabbitMQContainer rabbitMQContainer = new RabbitMQContainer("rabbitmq:3.12-management")
            .waitingFor(Wait.forLogMessage(".*Server startup complete.*", 1)
            .withStartupTimeout(Duration.ofMinutes(2)));

